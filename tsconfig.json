{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "Node16",
    "outDir": "dist",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true
  },
  "include": ["apps/**/*.ts", "core/**/*.ts", "filters/**/*.ts", "notifiers/**/*.ts", "utils/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
