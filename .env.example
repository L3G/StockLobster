# Strategy selection: momentum | breakout | default
STRATEGY=momentum

# Filter thresholds (applied by the selected strategy)
MIN_PRICE=10
MAX_PRICE=
MIN_PERCENT_CHANGE=2
MAX_PERCENT_CHANGE=
MIN_VOLUME=1000000
REL_VOLUME=

# Trend filter
TREND_FILTER_ENABLED=true
TREND_WEAK_THRESHOLD=40
TREND_STRONG_THRESHOLD=65
RECENT_WINDOW_SIZE=8
ACCELERATION_WEIGHT=0.10
RECENT_WEIGHT_MULTIPLIER=1.5
CHART_INTERVAL=5m
CHART_RANGE=1d

# OpenClaw integration
OPENCLAW_GATEWAY_URL=http://localhost:3000/api/ingest
OPENCLAW_API_KEY=

# Polling config
POLL_INTERVAL_MS=300000

# Time window (hours, 24h format) — leave empty for always-on
TIME_WINDOW_START=
TIME_WINDOW_END=

# Deduplication cooldown (ms) — suppress same symbol for this duration
DEDUPE_COOLDOWN_MS=900000

# Max signals per cycle
MAX_ALERTS=5

# Yahoo Finance auth (may be required)
YAHOO_CRUMB=
YAHOO_COOKIE=
