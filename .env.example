# OpenClaw integration
OPENCLAW_GATEWAY_URL=http://localhost:3000/api/ingest
OPENCLAW_API_KEY=

# Telegram notifications (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Polling config
POLL_INTERVAL_MS=300000

# Time window (hours, 24h format) — leave empty for always-on
TIME_WINDOW_START=9
TIME_WINDOW_END=16

# Yahoo Finance auth (may be required)
YAHOO_CRUMB=
YAHOO_COOKIE=
